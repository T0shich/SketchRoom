generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma" 
}

datasource db {
  provider = "postgresql"
}

model User {
  id   String @id @default(uuid())
  name String

  email    String @unique
  password String

  sessions      Session[]
  refreshTokens RefreshToken[]
  boards        Board[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Session {
  id     String @id @default(uuid())
  userId String
  token  String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Board {
  id      String @id @default(uuid())
  title   String @default("Новая доска")
  roomKey String @unique

  ownerId  String
  owner    User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  snapshot Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("boards")
}
